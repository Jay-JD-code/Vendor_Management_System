package com.vms.document.service;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.time.LocalDateTime;
import java.util.List;

import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import com.vms.document.entity.DocumentEntity;
import com.vms.document.repository.DocumentRepository;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class DocumentService {

	private final DocumentRepository documentRepository;
	
	private final String uploadDir = "uploads/";
	
	public DocumentEntity uploadFile(MultipartFile file, String vendorId, String documentType) throws IOException{
		
		String fileName = System.currentTimeMillis() + "_" + file.getOriginalFilename();
		
		Path path = Paths.get(uploadDir + fileName);
		
		Files.createDirectories(path.getParent());
		Files.write(path, file.getBytes());
		
		DocumentEntity doc = new DocumentEntity();
		doc.setVendorId(vendorId);
		doc.setFileName(fileName);
		doc.setFileType(file.getContentType());
		doc.setDocumentType(documentType);
		doc.setFilePath(fileName);
		doc.setUploadedAt(LocalDateTime.now());
		
		return documentRepository.save(doc);
	}
	
	public List<DocumentEntity> getVendorDocument(Long vendorId){
		return documentRepository.findByVendorId(vendorId);
	}
}
