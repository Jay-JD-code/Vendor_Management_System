server:
  port: 8080

spring:
 cloud:
  gateway:
   server:
    webmvc:
      routes:

        - id: auth-service
          uri: http://localhost:8081
          predicates:
            - Path=/api/auth/**

        - id: vendor-service
          uri: http://localhost:8082
          predicates:
            - Path=/api/vendors/**

        - id: order-service
          uri: http://localhost:8083
          predicates:
            - Path=/api/orders/**

        - id: payment-service
          uri: http://localhost:8084
          predicates:
            - Path=/api/payments/**

        - id: document-service
          uri: http://localhost:8085
          predicates:
            - Path=/api/documents/**